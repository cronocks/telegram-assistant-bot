# =============================================================================
# Environment Variables Template
# Copy this file to .env and fill in the actual values.
# Never commit .env to git — it is listed in .gitignore.
# =============================================================================


# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_TOKEN=

# Chat ID of the bootstrap admin (first user auto-registered on startup)
TELEGRAM_CHAT_ID=


# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# Optional: override the default Claude model
# MODEL=claude-haiku-4-5-20251001


# ── Google Drive & OAuth ───────────────────────────────────────────────────────
# Base64-encoded Google OAuth token (used instead of token.json file on server)
GOOGLE_OAUTH_TOKEN_B64=

# Optional: Google Drive folder ID for notes storage (leave empty to use root)
# GDRIVE_FOLDER_ID=

# Optional: subfolder name inside Drive for notes and wiki
# CLAUDE_NOTES_FOLDER=Claude-Notes
# WIKI_SUBFOLDER=Wiki


# ── Security & Ownership ──────────────────────────────────────────────────────
OWNER_EMAIL=

# Optional: allow ownership transfer via OAuth (set to false to disable)
# ENABLE_OWNERSHIP_TRANSFER=true

# Optional: max Drive file writes per hour (rate limiting)
# MAX_FILES_PER_HOUR=20


# ── Budget ────────────────────────────────────────────────────────────────────
# Monthly LLM spend limit in USD (hard cap across all users)
# BUDGET_LIMIT=10.0


# ── Wiki ──────────────────────────────────────────────────────────────────────
# Optional: tuning for wiki retrieval behavior
# MAX_WIKI_UPDATES=3
# MAX_WIKI_PAGES_CONTEXT=2
# MAX_WIKI_CONTEXT_CHARS=400


# ── Environment & SQLite ──────────────────────────────────────────────────────
# Deployment environment: 'local' | 'staging' | 'production'
# - local: SQLITE_PATH defaults to ./bot.db (no Litestream needed)
# - staging/production: SQLITE_PATH must be set explicitly (see below)
APP_ENV=local

# Path to the SQLite database file.
# local    → ./bot.db  (default, can omit)
# staging  → /data/bot.db
# production → /data/bot.db
# SQLITE_PATH=./bot.db


# ── Litestream (staging & production only) ────────────────────────────────────
# Not needed for local development (APP_ENV=local bypasses Litestream).
# Cloudflare R2 bucket name (must match the bucket created in R2 dashboard)
# LITESTREAM_BUCKET=telegram-bot-db

# Path within the bucket — keep staging and production separate to avoid
# overwriting each other's data.
# staging:    staging/bot.db
# production: production/bot.db
# LITESTREAM_DB_NAME=production/bot.db

# R2 S3-compatible endpoint: https://<account-id>.r2.cloudflarestorage.com
# LITESTREAM_ENDPOINT=

# R2 API token credentials (Object Read & Write, Account API token)
# LITESTREAM_ACCESS_KEY_ID=
# LITESTREAM_SECRET_ACCESS_KEY=


# ── Web UI (FR-5) ─────────────────────────────────────────────────────────────
# Secret key for the web channel. Required when APP_ENV != local (fail-fast at
# startup). In local mode, omitting it falls back to an insecure dev key.
#
# Generate a fresh strong key with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# IMPORTANT: use a DIFFERENT key for staging vs production. Never reuse.
# WEB_SECRET_KEY=

# Optional: session cookie TTL in days (default: 7)
# WEB_SESSION_TTL_DAYS=7
